# Google OAuth 2.0
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Gemini API
GEMINI_API_KEY=

# GCPプロジェクトID（デプロイ先。省略時は gcloud のデフォルトプロジェクト）
GCP_PROJECT_ID=

# 設定スプレッドシートID（Google Sheetsで新規作成し、URLからIDをコピー）
SETTINGS_SPREADSHEET_ID=

# 利用者フォルダルートID（Autofiler-CarePlanningと同じ共有ドライブのフォルダID）
USER_ROOT_FOLDER_ID=

# カスタムドメイン（設定済みの場合。OAuthコールバックやBASE_URLに使用）
# 例: careplan.care-planning.co.jp
CUSTOM_DOMAIN=

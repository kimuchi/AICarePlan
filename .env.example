# Google OAuth 2.0
OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-client-secret

# Session
SESSION_SECRET=random-session-secret-change-this

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Google Sheets - 設定スプレッドシートID（初回起動時に自動作成、作成後ここに記入）
SETTINGS_SPREADSHEET_ID=

# Google Drive - 利用者フォルダルートID
USER_ROOT_FOLDER_ID=shared-drive-user-folder-root-id

# Google Drive - マイドライブ側利用者フォルダルートID（機密文書用）
USER_ROOT_FOLDER_ID_PRIVATE=

# サーバーポート
PORT=3001

# 本番環境URL（OAuth コールバック用）
BASE_URL=http://localhost:3001

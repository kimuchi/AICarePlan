# Google OAuth 2.0
OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-client-secret

# Session
SESSION_SECRET=random-session-secret-change-this

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Gemini モデル設定
#   GEMINI_MODEL_GENERATE : ケアプラン生成用（高品質推奨）
#   GEMINI_MODEL_ANALYZE  : PDF解析・要約用（高速・低コスト推奨）
GEMINI_MODEL_GENERATE=gemini-2.5-flash-preview-05-20
GEMINI_MODEL_ANALYZE=gemini-2.0-flash

# Google Sheets - 設定スプレッドシートID（初回起動時に自動作成、作成後ここに記入）
SETTINGS_SPREADSHEET_ID=

# Google Drive - 利用者フォルダルートID（共有ドライブ）
USER_ROOT_FOLDER_ID=shared-drive-user-folder-root-id

# マイドライブ機密フォルダ名
#   Autofiler-CarePlanningの getConfidentialRootFolder() が
#   マイドライブ直下に作成するフォルダ名。変更不要です。
PRIVATE_FOLDER_NAME=利用者フォルダ

# サーバーポート（Cloud Runでは自動設定されるため記入不要）
PORT=

# 本番環境URL（Cloud Runデプロイ時に自動設定されるため記入不要）
# npm run deploy:cloudrun がデプロイ後のURLを自動で設定します。
BASE_URL=
